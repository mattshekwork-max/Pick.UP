# Pick.UP Environment Variables
# Copy this to .env.local and fill in your values

# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_key

# Phone & SMS (Twilio)
# Keep ENABLE_SMS_RECAPS=false until SMS is intentionally enabled for paying clients.
ENABLE_SMS_RECAPS=false
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

# AI Voice (Vapi)
VAPI_API_KEY=your_vapi_api_key
VAPI_WEBHOOK_SECRET=your_webhook_secret
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# App Configuration
NEXT_PUBLIC_APP_NAME=Pick.UP
NEXT_PUBLIC_APP_URL=https://pickuphone.com

# Google Calendar OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://pickuphone.com/api/auth/google/callback

# Payments (Stripe - Optional)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_key
STRIPE_SECRET_KEY=your_stripe_secret

# Email (Resend - Optional)
RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=noreply@pickuphone.com
